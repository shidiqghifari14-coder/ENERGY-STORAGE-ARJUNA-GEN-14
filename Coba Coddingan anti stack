//handle button nextion for request current
void handleNextionInput(){
  while(NEXTION_SERIAL.available()){
    uint8_t inByte = NEXTION_SERIAL.peek();

    if(inByte == 0x65){
      if(NEXTION_SERIAL.available() < 7) return; // paket belum lengkap, tunggu loop berikutnya
      NEXTION_SERIAL.read(); // buang header
      uint8_t page  = NEXTION_SERIAL.read();
      uint8_t compID = NEXTION_SERIAL.read();
      uint8_t event = NEXTION_SERIAL.read();
      NEXTION_SERIAL.read(); NEXTION_SERIAL.read(); NEXTION_SERIAL.read(); // buang 0xFF x3

      if(compID >= 2 && compID <= 7){
    pendingCurrent = compID - 1;
      sendToNextion("n_current.val=" + String(pendingCurrent)); 
    // waitingApply = true;
    SerialBT.print("PendingCurrent: ");
    SerialBT.println(pendingCurrent);
}
      else if(compID == PL_BUTTON_COMPID){ //Fungsi untuk Power Limit
        togglePowerLimit();
      }
      // continue; // cek lagi siapa tau ada numpuk
    }
    else if(inByte == 0x71){
      if(NEXTION_SERIAL.available() < 8) return;
      NEXTION_SERIAL.read(); // buang header
      uint8_t val[4];
      for(int i = 0; i < 4; i++) val[i] = NEXTION_SERIAL.read();
      NEXTION_SERIAL.read(); NEXTION_SERIAL.read(); NEXTION_SERIAL.read(); // buang terminator

      uint32_t reqVal = val[0] | (val[1] << 8) | (val[2] << 16) | (val[3] << 24);
      SerialBT.print(">> Nextion req current: ");
      SerialBT.println(reqVal);

// //Opsi bisa tapi gabisa ganti n_Current======
//       if(reqVal >= 1 && reqVal <= 6){
//         currentVal = reqVal * 10;
//         cased = 0;
//         stopCharg = 0;
//         x = 0x0F;
//         y = 0xA0;

//        if(powerLimitActive){
//         autoLimitCurrent();
//        }
// //=======

       if(reqVal >=1 && reqVal <= 6 && powerLimitActive == true){
        currentVal = reqVal *10;
        cased = 0;
        stopCharg = 0;
        x = 0x0F;
        y = 0xA0;
        autoLimitCurrent();
        sendToNextion("n_current.val=" + String(reqVal));
        SerialBT.print(">> APPLIED (PL ON): ");
        SerialBT.print(reqVal);
        SerialBT.println(" A");
        updateStatusNextion();
       }
       else if(reqVal >=1 && reqVal <= 6 && powerLimitActive == false){
        currentVal = reqVal*10;
        cased = 0;
        stopCharg = 0;
        x = 0x0F;
        y = 0xA0;
        sendToNextion("n_current.val=" + String(reqVal));
        SerialBT.print(">> APPLIED (PL OFF): ");
        SerialBT.print(reqVal);
        SerialBT.println(" A");
        updateStatusNextion();
       }
        // sendToNextion("n_current.val=" + String(reqVal));
        // SerialBT.print(">> APPLIED: ");
        // SerialBT.print(reqVal);
        // SerialBT.println(" A");
        // updateStatusNextion();
      } else {
        SerialBT.println(">>> ERROR: Invalid current value!");
      }
      // continue;
    }
    else {
      NEXTION_SERIAL.read(); // byte sampah 
    }
  }
}

