//POWER LIMIT TOGGLE (via Bluetooth "PL" atau tombol Nextion) 
void updatePowerLimitNextion(){
  if(powerLimitActive){
    sendToNextion("t_pl.pco=2016");        // hijau = PL aktif
    sendToNextion("t_pl.txt=\"PL\"");
  } else {
    sendToNextion("t_pl.pco=17599");       // biru muda = PL nonaktif
    sendToNextion("t_pl.txt=\"PL\"");
  }
}

void togglePowerLimit(){
  powerLimitActive = !powerLimitActive;
  if(powerLimitActive == true){
  autoLimitCurrent();
  SerialBT.println(">> Power Limit: ON");
  updatePowerLimitNextion();
}
else{
  SerialBT.println(">>Power Limit: OFF");
}

}

void updateStatusNextion(){
if(errFlag != 0){
sendToNextion("t_status.pco=63488"); // Red color
sendToNextion("t_status.txt=\"CHARGING FAULT\"");
}
else if(RFE == 1 && stopCharg == 0){
sendToNextion("t_status.pco=2016"); // Green color
sendToNextion("t_status.txt=\"START CHARGING\"");
}
else if(stopCharg == 1 || RFE == 0){
sendToNextion("t_status.pco=65504");  
 sendToNextion("t_status.txt=\"STOP CHARGING\"");
 }
 else {
 sendToNextion("t_status.pco=17599"); 
 sendToNextion("t_status.txt=\"IDLE STATE\"");
 }
}

void updateErrorNextion(){
   
 if(errFlag == 0){
 sendToNextion("t_error.pco=2016");   // hijau
 sendToNextion("t_error.txt=\"STATUS OK\"");          
 }
 else{
 String errorText;
 errorText.reserve(50);     // alokasi memori duluan

 if(bitRead(errFlag, 0)) errorText += "HWFail;";
 if(bitRead(errFlag, 1)) errorText += "OvrTmp;";
 if(bitRead(errFlag, 2)) errorText += "VoltER;";
 if(bitRead(errFlag, 3)) errorText += "BattNC;";
 if(bitRead(errFlag, 4)) errorText += "TmOut;";

 sendToNextion("t_error.pco=63488");    // merah
 sendToNextion("t_error.txt=\"" + errorText + "\"");
 }
}

