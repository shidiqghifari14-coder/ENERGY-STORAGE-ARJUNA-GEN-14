 mergeV = (canData[0] << 8) | canData[1]; 
 mergeC = (canData[2] << 8) | canData[3]; 
 errFlag = canData[4];
 mergeVValid = true;
 decodeErrorFlags();

 String receiveData = "VOLTAGE = " + String(mergeV) + "CURRENT = " + String(mergeC) + "ERR = " + String (errFlag, BIN);
 // SerialBT.print(receiveData);
 SerialBT.println(receiveData);

 Serial.print("VOLTAGE: ");Serial.println(mergeV);
 Serial.print("CURRENT : ");Serial.println(mergeC);
 Serial.print("ERR  : ");Serial.println(errFlag, BIN);
SerialBT.print("VOLTAGE: ");Serial.println(mergeV);
 SerialBT.print("CURRENT : ");Serial.println(mergeC);
  SerialBT.print("ERR  : ");Serial.println(errFlag, BIN);
 }
}

void decodeErrorFlags(){
// Bit0: Hardware Failure
 if (bitRead(errFlag, 0) == 1 ){
 Serial.print("Hardware Failure");
 SerialBT.print("Hardware Failure");
 } 
 // Bit1: Temperature of Charger
 if (bitRead(errFlag, 1) == 1){
 Serial.print("Temperature: Over temperature protection");
 SerialBT.print("Temperature: Over temperature protection");
 }
 // Bit2: Input Voltage
 if (bitRead(errFlag, 2) == 1){
 Serial.print("Input Voltage: WRONG, charger will stop");
 SerialBT.print("Input Voltage: WRONG, charger will stop");
 }
 // Bit3: Starting State
 if (bitRead(errFlag, 3) == 1){
 Serial.print("Starting State: Battery not connected or reverse polarity");
 SerialBT.print("Starting State: Battery not connected or reverse polarity");
 }
 // Bit4: Communication State
 if (bitRead(errFlag, 4) == 1){
 Serial.print("Communication State: Timeout");
 SerialBT.print("Communication State: Timeout");
 }

 Serial.println();
 SerialBT.println();
}

// Limit Power 1360W
void autoLimitCurrent() {
  float actualVoltageP = mergeV / 10.0f;
  if (!mergeVValid || cased == 7 || stopCharg != 0) return;
  if (actualVoltageP <= 0.1f) return; 

  float currentLimitA = 1360.0f / actualVoltageP;
  float currentRawLimit = currentLimitA * 10.0f;

  if (currentRawLimit > 60) currentRawLimit = 60;

  if (currentVal > currentRawLimit) {
    currentVal = (uint8_t)currentRawLimit; // Cast ke uint8_t agar sesuai tipe data currentVal
    SerialBT.print(" AUTO LIMIT ACTIVE: V=");
    SerialBT.print(actualVoltage, 1);
    SerialBT.print("V Limit=");
    SerialBT.print(currentLimitA, 2);
    SerialBT.println("A");
  }
}

